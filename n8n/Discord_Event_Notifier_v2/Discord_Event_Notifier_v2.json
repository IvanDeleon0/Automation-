    {
      "parameters": {
        "authentication": "webhook",
        "content": "=━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n# 🌟 AWS LEARNING CLUB POLAR\n### 📅 NEW EVENT SCHEDULED\n\n```ansi\n\u001b[1;32m        ● EVENT STATUS: SCHEDULED ●\u001b[0m\n```\n\n# 📢 {{ $('If').item.json[' Event Name'] }}\n\n👋 Hello @everyone!\n\nA brand-new event has just been scheduled! Get ready to learn, collaborate, and build alongside the AWS Learning Club POLAR community.\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n📅 Date\n> {{ $('If').item.json.date }}\n🕒 Time\n> {{ $('If').item.json.startTime }} - {{ $('If').item.json.endTime }}\n\n📍 Venue\n> {{ $('If').item.json.Venue }}\n\n🎤 Speaker\n> {{ $('If').item.json.Speaker }}\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n### 📝 Event Overview\n\n> {{ $('If').item.json['Event Description'] }}\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n### 🔗 Registration\n\n{{ $('If').item.json['Registration Link'] }}\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n🆔 Tracking ID\n{{ $('If').item.json['Event ID'] }}\n\n❄️ *Powered by the POLAR Automation Engine*",
        "options": {
          "username": "@everyone"
        },
