      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const event =$json[\"Event Time\"];\n\nif (!event) {\n  throw new Error(\"Event Time is missing.\");\n}\n\nconst parts = event.split(\" | \");\n\nif (parts.length !== 2) {\n  throw new Error(`Invalid Event Time format: ${event}`);\n}\n\nconst date = parts[0];\nconst range = parts[1];\n\nconst [startTime, endTime] = range.split(\" - \");\n\nreturn {\n  json: {\n    ...$json,\n    date,\n    startTime,\n    endTime,\n    startDateTime: `${date} ${startTime}`,\n    endDateTime: `${date} ${endTime}`,\n  },\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
