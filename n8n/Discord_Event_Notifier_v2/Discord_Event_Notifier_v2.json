    {
      "parameters": {
        "sendTo": "={{ $json.Gmail }}",
        "subject": "Event Polar Schedule",
        "message": "=<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Event Scheduled</title>\n</head>\n<body style=\"margin:0; padding:0; background-color:#f4f5f7; font-family:Georgia, 'Times New Roman', Times, serif;\">\n<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#f4f5f7; padding:30px 0;\">\n  <tr>\n    <td align=\"center\">\n      <table role=\"presentation\" width=\"520\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#ffffff; border-radius:10px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,0.08); border:1px solid #e5e5e5;\">\n        <!-- Header -->\n        <tr>\n          <td style=\"background:linear-gradient(135deg,#7b2ff7 0%,#a855f7 50%,#c084fc 100%); padding:28px 32px; text-align:center;\">\n            <p style=\"margin:0 0 8px 0; font-size:11px; font-weight:600; letter-spacing:3px; color:#eddcff; text-transform:uppercase;\">\n              Event Update\n            </p>\n            <h1 style=\"margin:0; color:#ffffff; font-size:24px; font-weight:400; letter-spacing:0.5px;\">\n              Event Scheduled\n            </h1>\n          </td>\n        </tr>\n        <!-- Body -->\n        <tr>\n          <td style=\"padding:36px 32px; color:#333333; font-size:14.5px; line-height:1.75;\">\n            <p style=\"margin-top:0;\">Dear <strong>{{ $json.Name }}</strong>,</p>\n            <p>\n            We're pleased to inform you that the following event has been <strong style=\"color:#7b2ff7;\">scheduled</strong>:\n            </p>\n            <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#f7f1ff; border-left:4px solid #7b2ff7; border-radius:4px; margin:20px 0;\">\n              <tr>\n                <td style=\"padding:16px 18px;\">\n                  <p style=\"margin:0; color:#8a8a8a; font-size:11px; text-transform:uppercase; letter-spacing:1px; font-weight:600;\">Event</p>\n                  <p style=\"margin:5px 0 0 0; color:#202124; font-size:17px; font-weight:600; letter-spacing:0.2px;\">{{ $json['Event Name'] }}</p>\n                </td>\n              </tr>\n              <tr>\n                <td style=\"padding:0 18px 16px 18px;\">\n                  <p style=\"margin:0; color:#8a8a8a; font-size:11px; text-transform:uppercase; letter-spacing:1px; font-weight:600;\">Date &amp; Time</p>\n                  <p style=\"margin:5px 0 0 0; color:#202124; font-size:15px; font-weight:500;\">{{ $('If1').item.json['Event Time'] }}</p>\n                </td>\n              </tr>\n              <tr>\n                <td style=\"padding:0 18px 16px 18px;\">\n                  <p style=\"margin:0; color:#8a8a8a; font-size:11px; text-transform:uppercase; letter-spacing:1px; font-weight:600;\">Location</p>\n                  <p style=\"margin:5px 0 0 0; color:#202124; font-size:15px; font-weight:500;\">{{ $('If1').item.json.Venue }}</p>\n                </td>\n              </tr>\n            </table>\n            <p>\n            Please mark your calendar accordingly. If any changes occur, you will be notified as soon as an official update is available.\n            </p>\n            <p>\n            If you have any questions or need to confirm your attendance, please don't hesitate to reach out to us.\n            </p>\n            <div style=\"height:1px; background-color:#ececec; margin:26px 0;\"></div>\n            <p style=\"margin:0 0 4px 0;\">\n            We look forward to seeing you there,\n            </p>\n            <p style=\"margin:0; font-weight:700; color:#202124;\">\n            The Events Team\n            </p>\n          </td>\n        </tr>\n        <!-- Footer -->\n        <tr>\n          <td style=\"background-color:#f5f0fb; padding:20px 32px; text-align:center; border-top:1px solid #e5e5e5;\">\n            <p style=\"margin:0; color:#9a9a9a; font-size:11px; line-height:1.6; letter-spacing:0.2px;\">\n            This is an automated notification. Please do not reply directly to this email unless reporting an issue.\n            </p>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>\n</body>\n</html>",
        "options": {}
      },
